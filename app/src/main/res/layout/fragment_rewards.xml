<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/welcome_gradient_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="24dp">

        <!-- ══════════════════════════
             HEADER
             ══════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏆 Earned Points"
            android:textColor="@android:color/white"
            android:textSize="26sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"
            android:layout_gravity="center"
            android:layout_marginTop="28dp"
            android:shadowColor="#55000000"
            android:shadowDx="0"
            android:shadowDy="2"
            android:shadowRadius="6" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Participate and earn rewards for your community!"
            android:textColor="#B3DFFF"
            android:textSize="12sp"
            android:layout_gravity="center"
            android:gravity="center"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="20dp" />

        <!-- ══════════════════════════
             TOTAL POINTS CARD
             ══════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="24dp"
            app:cardElevation="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TOTAL POINTS"
                        android:textColor="#1565C0"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:alpha="0.6" />

                    <TextView
                        android:id="@+id/tvTotalPoints"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#0D47A1"
                        android:textSize="56sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-black"
                        android:lineSpacingMultiplier="0.9"
                        android:layout_marginTop="2dp" />

                    <TextView
                        android:id="@+id/tvProgressLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Loading rewards..."
                        android:textColor="#1976D2"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="6dp" />

                    <ProgressBar
                        android:id="@+id/progressPoints"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="10dp"
                        android:max="100"
                        android:progress="0"
                        android:progressTint="#FFA726"
                        android:progressBackgroundTint="#E3F2FD" />

                </LinearLayout>

                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:src="@drawable/reward_coins_stack"
                    android:scaleType="fitCenter"
                    android:layout_marginStart="12dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ══════════════════════════
             SECTION LABEL
             ══════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎁  Choose Your Reward"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:shadowColor="#44000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="4"
            android:layout_marginBottom="10dp" />

        <!-- ══════════════════════════
             CATEGORY FILTER TABS
             ══════════════════════════ -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTabAll"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="All"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    android:backgroundTint="@android:color/white"
                    android:textColor="#0D47A1"
                    android:layout_marginEnd="8dp"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTabFood"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="🍱 Food"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    android:backgroundTint="#FFE0B2"
                    android:textColor="#BF360C"
                    android:layout_marginEnd="8dp"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTabSchool"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="🎒 School"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    android:backgroundTint="#BBDEFB"
                    android:textColor="#0D3B8C"
                    android:layout_marginEnd="8dp"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTabHygiene"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="🧴 Hygiene"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    android:backgroundTint="#C8E6C9"
                    android:textColor="#1B5E20"
                    android:layout_marginEnd="8dp"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTabHousehold"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="🏠 Household"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    android:backgroundTint="#E1BEE7"
                    android:textColor="#4A0072"
                    app:cornerRadius="18dp" />

            </LinearLayout>
        </HorizontalScrollView>

        <!-- ══════════════════════════
             REWARDS LIST
             ══════════════════════════ -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvRewards"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:clipToPadding="false" />

        <!-- Empty state -->
        <TextView
            android:id="@+id/tvEmptyRewards"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No rewards available in this category."
            android:textColor="#B3DFFF"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginTop="24dp"
            android:visibility="gone" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
