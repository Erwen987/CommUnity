<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/welcome_gradient_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="28dp">

        <!-- ── Header ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏆 Earned Points"
            android:textColor="@android:color/white"
            android:textSize="30sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:layout_gravity="center"
            android:layout_marginTop="28dp"
            android:shadowColor="#44000000"
            android:shadowDx="0"
            android:shadowDy="2"
            android:shadowRadius="4" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Participate and earn rewards for your community!"
            android:textColor="#CCE4FF"
            android:textSize="13sp"
            android:layout_gravity="center"
            android:gravity="center"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="20dp" />

        <!-- ── Total Points Card ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@color/surface_card"
            app:cardCornerRadius="22dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="22dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TOTAL POINTS"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/tvTotalPoints"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#F59E0B"
                        android:textSize="56sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-black"
                        android:lineSpacingMultiplier="0.9"
                        android:layout_marginTop="2dp" />

                    <TextView
                        android:id="@+id/tvProgressLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Loading rewards..."
                        android:textColor="@color/text_primary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="6dp" />

                    <ProgressBar
                        android:id="@+id/progressPoints"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:max="100"
                        android:progress="0"
                        android:progressTint="#F59E0B"
                        android:progressBackgroundTint="#F3F4F6" />

                </LinearLayout>

                <ImageView
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:src="@drawable/reward_coins_stack"
                    android:scaleType="fitCenter"
                    android:layout_marginStart="12dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ── Section Label ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎁  Choose Your Reward"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:shadowColor="#44000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="4"
            android:layout_marginBottom="10dp" />

        <!-- ── Category Tabs ── -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTabAll"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:text="All"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    android:backgroundTint="@color/surface_card"
                    android:textColor="@color/text_primary"
                    android:layout_marginEnd="8dp"
                    app:cornerRadius="19dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTabFood"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:text="🍱 Food"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    android:backgroundTint="#FEF3C7"
                    android:textColor="#92400E"
                    android:layout_marginEnd="8dp"
                    app:cornerRadius="19dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTabSchool"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:text="🎒 School"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    android:backgroundTint="#DBEAFE"
                    android:textColor="#1E40AF"
                    android:layout_marginEnd="8dp"
                    app:cornerRadius="19dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTabHygiene"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:text="🧴 Hygiene"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    android:backgroundTint="#DCFCE7"
                    android:textColor="#14532D"
                    android:layout_marginEnd="8dp"
                    app:cornerRadius="19dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTabHousehold"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:text="🏠 Household"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    android:backgroundTint="#EDE9FE"
                    android:textColor="#4C1D95"
                    app:cornerRadius="19dp" />

            </LinearLayout>
        </HorizontalScrollView>

        <!-- ── Rewards List ── -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvRewards"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:clipToPadding="false" />

        <TextView
            android:id="@+id/tvEmptyRewards"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No rewards available in this category."
            android:textColor="#90BFF0"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginTop="32dp"
            android:visibility="gone" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
